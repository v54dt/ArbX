# fubon_neo 2.2.8 caps at Python 3.13
FROM python:3.13-slim-bookworm
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY python-sidecar/ ./
RUN pip install uv && uv pip install --system -e .[tw-stock]
ENV TZ=Asia/Taipei
ENTRYPOINT ["python", "-m", "src.main"]
CMD ["config/fubon.yaml"]
