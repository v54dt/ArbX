# Binance
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
BINANCE_TESTNET_API_KEY=your_testnet_key
BINANCE_TESTNET_API_SECRET=your_testnet_secret

# OKX
OKX_API_KEY=your_api_key_here
OKX_API_SECRET=your_api_secret_here
OKX_PASSPHRASE=your_passphrase_here

# Bybit
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# Shioaji (永豐)
SHIOAJI_API_KEY=your_api_key_here
SHIOAJI_SECRET_KEY=your_secret_key_here
SHIOAJI_CA_PATH=/path/to/Sinopac.pfx
SHIOAJI_CA_PASSWORD=your_ca_password
SHIOAJI_PERSON_ID=your_person_id

# Fubon (富邦)
FUBON_USER_ID=your_user_id
FUBON_PASSWORD=your_password
FUBON_PFX_PATH=/path/to/cert.pfx
FUBON_PFX_PASSWORD=your_pfx_password
